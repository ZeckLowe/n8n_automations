      "parameters": {
        "jsCode": "// --- DATA PREPARATION ---\nLOAD allCards FROM input_data\nSET user_lookup_table TO [\n  ...\n]\nINITIALIZE results_list AS empty array\n\n// --- HELPER LOGIC ---\n\nFUNCTION find_name_by_id(id_to_find):\n    FOR EACH entry IN user_lookup_table:\n        IF entry[0] EQUALS id_to_find:\n            RETURN entry[1] // Found Name\n    RETURN NULL // Default if not found\n\nFUNCTION get_url_from_string(text):\n    DEFINE regex_pattern AS \"http...ending in .htm\"\n    FIND pattern IN text\n    IF pattern is found:\n        RETURN specific match\n    ELSE:\n        RETURN NULL\n\n// --- MAIN EXECUTION ---\n\nFOR EACH card IN allCards:\n    // Extract raw data\n    SET current_name TO card.json.name\n    SET current_id TO card.json.id\n    SET current_list_id TO card.json.idList\n\n    // Transform data\n    SET extracted_url TO get_url_from_string(current_name)\n    SET list_owner TO find_name_by_id(current_list_id)\n\n    // Build output structure\n    CREATE new_record WITH:\n        cardId: current_id\n        url: extracted_url\n        listName: list_owner\n\n    ADD new_record TO results_list\n\n// --- OUTPUT ---\nRETURN results_list"
      },
